{
  "name": "openai-auth-tester",
  "version": "1.0.0",
  "description": "Automated Node.js testing tool for OpenAI authentication signup flow",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" --fix",
    "start": "node src/index.js"
