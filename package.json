    "tough-cookie": "^4.1.3",
    "playwright": "^1.41.2",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "fast-check": "^3.15.1",
    "vitest": "^1.3.1",
    "eslint": "^8.57.0"
  }
